{
  "info": {
    "name": "ENEM API Futura",
    "description": "Coleção completa para testar a ENEM API. Use a variável `base_url` para trocar entre local e produção.",
    "_postman_id": "enem-api-futura-v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string",
      "description": "Trocar para a URL de produção quando necessário"
    },
    {
      "key": "year",
      "value": "2023",
      "type": "string"
    },
    {
      "key": "index",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Spec / Docs",
      "item": [
        {
          "name": "GET OpenAPI Spec",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/v1",
              "host": ["{{base_url}}"],
              "path": ["v1"]
            },
            "description": "Retorna a especificação OpenAPI completa da API."
          }
        }
      ]
    },
    {
      "name": "Exams",
      "item": [
        {
          "name": "GET Listar todos os exames",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/v1/exams",
              "host": ["{{base_url}}"],
              "path": ["v1", "exams"]
            },
            "description": "Lista todos os anos disponíveis (2009–2023)."
          }
        },
        {
          "name": "GET Detalhes de um exame",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/v1/exams/{{year}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "exams", "{{year}}"]
            },
            "description": "Retorna metadados do exame de um ano: lista de questões (index + discipline), idiomas disponíveis etc."
          }
        },
        {
          "name": "GET Detalhes — ano inválido (erro 404)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/v1/exams/1999",
              "host": ["{{base_url}}"],
              "path": ["v1", "exams", "1999"]
            },
            "description": "Espera 404 not_found."
          }
        }
      ]
    },
    {
      "name": "Questions — Filtros",
      "item": [
        {
          "name": "GET Questões — sem filtro (paginação padrão)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/v1/exams/{{year}}/questions?limit=10&offset=0",
              "host": ["{{base_url}}"],
              "path": ["v1", "exams", "{{year}}", "questions"],
              "query": [
                { "key": "limit", "value": "10" },
                { "key": "offset", "value": "0" }
              ]
            },
            "description": "Primeiras 10 questões do exame. Resposta inclui metadata.total e hasMore."
