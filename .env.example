# Database
DATABASE_URL="postgresql://user:password@localhost:5432/enem-api"
DATABASE_URL_UNPOOLED="postgresql://user:password@localhost:5432/enem-api"

# LLM Classification Configuration
# Choose provider: "groq" or "ollama"
LLM_PROVIDER="ollama"

# For Ollama
OLLAMA_BASE_URL="http://localhost:11434/v1"
OLLAMA_MODEL="qwen2.5:7b-instruct-q4_K_M"
CLASSIFY_CONCURRENCY="4"

# For Groq
# GROQ_API_KEY="your-groq-api-key"
